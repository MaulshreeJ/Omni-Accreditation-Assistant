# Groq API Keys (Multi-key pool for load balancing)
# REQUIRED for LLM synthesis in production
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY_1=gsk_your_first_key_here
GROQ_API_KEY_2=gsk_your_second_key_here

# LangSmith API Key (For observability)
LANGCHAIN_API_KEY=ls_your_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=omni-accreditation-copilot

# HuggingFace Token (Recommended for better model download rates)
# Get your token from: https://huggingface.co/settings/tokens
# Without this token, you may experience rate limiting
HF_TOKEN=hf_your_token_here

# Optional: Ollama Configuration
# OLLAMA_HOST=http://localhost:11434
